---
import { readdirSync, readFileSync } from "node:fs";
import { imageSize } from "image-size";

// Any image dropped into public/photos/ is picked up automatically.
const photosDir = new URL("../../public/photos", import.meta.url);
const photoFiles = readdirSync(photosDir)
	.filter((name) => /\.(jpe?g|png|webp|gif)$/i.test(name));

// Look up real dimensions so we can find landscape shots and group the gallery by orientation.
const sized = photoFiles.map((name) => {
	const { width, height } = imageSize(readFileSync(new URL(`./${name}`, `${photosDir}/`)));
	return {
		src: `/photos/${encodeURIComponent(name)}`,
		landscape: width > height,
	};
});

const gallery = sized;
const slideshow = sized.filter((p) => p.landscape).map((p) => p.src);

// Group into rows: a landscape photo takes the space of two portraits,
// so each row holds either 4 portraits, or 2 portraits + 1 landscape.
type Row = { items: typeof gallery; cols: number };
const rows: Row[] = [];
let row: typeof gallery = [];
let used = 0;
for (const photo of gallery) {
	const cost = photo.landscape ? 2 : 1;
	if (used + cost > 4) {
		rows.push({ items: row, cols: used });
		row = [];
		used = 0;
	}
	row.push(photo);
	used += cost;
}
if (row.length) rows.push({ items: row, cols: used });

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Photo Gallery</title>
	</head>
	<body>
		<header class="site-header">
			<span class="logo">PHOTOS</span>
		</header>

		<main>
			<section class="hero">
				<h1>Photo Gallery</h1>
				<p>A collection of moments, captured one frame at a time.</p>
			</section>

			<section class="camera-section" aria-label="Featured slideshow">
				<div class="camera">
					<img class="camera-outline" src="/camera-outline.png" alt="" />
					<div class="camera-screen">
						{slideshow.map((src, i) => (
							<img
								class="slide"
								src={src}
								alt=""
								loading={i === 0 ? "eager" : "lazy"}
								style={`--i: ${i}; --n: ${slideshow.length}`}
							/>
						))}
					</div>
				</div>
			</section>

			<section class="gallery">
				<h2>Gallery</h2>
				{rows.map((r) => (
					<div class="grid-row" style={`--cols: ${r.cols}`}>
						{r.items.map((photo) => (
							<button
								class:list={["grid-item", photo.landscape ? "landscape" : "portrait"]}
								data-full={photo.src}
							>
								<img src={photo.src} alt="" loading="lazy" />
							</button>
						))}
					</div>
				))}
			</section>
		</main>

		<div class="lightbox" id="lightbox">
			<img id="lightbox-img" src="" alt="" />
		</div>
	</body>
</html>

<script>
	const lightbox = document.getElementById("lightbox") as HTMLDivElement;
	const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;

	document.querySelectorAll<HTMLButtonElement>(".grid-item").forEach((item) => {
		item.addEventListener("click", () => {
			const full = item.dataset.full;
			if (!full) return;
			lightboxImg.src = full;
			lightbox.classList.add("open");
		});
	});

	lightbox.addEventListener("click", () => {
		lightbox.classList.remove("open");
		lightboxImg.src = "";
	});

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") {
			lightbox.classList.remove("open");
			lightboxImg.src = "";
		}
	});
</script>

<style is:global>
	:root {
		color-scheme: dark;
		font-family: "Segoe UI", system-ui, sans-serif;
	}
	* {
		box-sizing: border-box;
	}
	body {
		margin: 0;
		background: #1a1a1a;
		color: #f2f2f2;
	}
</style>

<style>
	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem 3rem;
	}
	.logo {
		font-weight: 800;
		letter-spacing: 0.15em;
	}

	.hero {
		text-align: center;
		padding: 3rem 1.5rem 2rem;
	}
	.hero h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		margin: 0 0 0.5rem;
		font-weight: 800;
	}
	.hero p {
		color: #999;
		margin: 0;
	}

	/* --- Camera + slideshow --- */
	.camera-section {
		display: flex;
		justify-content: center;
		padding: 2rem 1.5rem 4rem;
	}
	.camera {
		position: relative;
		width: min(90vw, 720px);
	}
	.camera-outline {
		display: block;
		width: 100%;
		height: auto;
		position: relative;
		z-index: 2;
		/* outline extracted with a transparent background, so the page's
		   dark gray shows through instead of the original pure black */
	}
	/* Screen cut-out sits at the same relative position as the LCD in the sketch */
	.camera-screen {
		position: absolute;
		left: 25.6%;
		top: 41.5%;
		width: 39.4%;
		height: 50%;
		overflow: hidden;
		border-radius: 2px;
		z-index: 1;
		background: #000;
	}
	.slide {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0;
		animation: slideshow calc(var(--n) * 5s) infinite;
		animation-delay: calc(var(--i) * 5s);
	}
	@keyframes slideshow {
		0% { opacity: 0; }
		4% { opacity: 1; }
		16% { opacity: 1; }
		20% { opacity: 0; }
		100% { opacity: 0; }
	}

	/* --- Recent gallery grid --- */
	.gallery {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1.5rem 5rem;
	}
	.gallery h2 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}
	.grid-row {
		display: grid;
		grid-template-columns: repeat(var(--cols), 1fr);
		align-items: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.grid-item {
		overflow: hidden;
		border-radius: 0.75rem;
		border: none;
		padding: 0;
		cursor: pointer;
		background: #2a2a2a;
	}
	.grid-item.portrait {
		grid-column: span 1;
		aspect-ratio: 3 / 4;
	}
	.grid-item.landscape {
		grid-column: span 2;
		aspect-ratio: 16 / 9;
	}
	.grid-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s ease;
	}
	.grid-item:hover img {
		transform: scale(1.05);
	}

	/* --- Lightbox --- */
	.lightbox {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.92);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.25s ease;
		z-index: 100;
		cursor: zoom-out;
	}
	.lightbox.open {
		opacity: 1;
		visibility: visible;
	}
	.lightbox img {
		max-width: 92vw;
		max-height: 92vh;
		object-fit: contain;
		border-radius: 0.5rem;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7);
	}
</style>
