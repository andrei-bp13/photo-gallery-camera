	/* --- Camera + slideshow --- */
	.camera-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 1.5rem 1.5rem 4rem;
	}
	.camera {
		position: relative;
		width: min(90vw, 720px);
	}
	.camera-outline {
		display: block;
		width: 100%;
		height: auto;
		position: relative;
		z-index: 2;
		/* outline extracted with a transparent background, so the page's
		   dark gray shows through instead of the original pure black */
	}
	/* Sits inside the smaller inner rectangle of the LCD, not the outer bezel */
	.camera-screen {
		position: absolute;
		left: 30.3%;
		top: 43.7%;
		width: 31.2%;
		height: 42.4%;
		overflow: hidden;
		border-radius: 2px;
		z-index: 1;
		background: #000;
	}
	/* Each slide goes through: fade in (blurred) -> AF brackets blink while
	   focusing -> snap to sharp (brackets gone), like taking a photo. */
	.slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.35s ease;
	}
	.slide.active {
		opacity: 1;
	}
	.slide img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: blur(7px);
		transition: filter 0.2s ease-out;
	}
	.slide.sharp img {
		filter: blur(0);
