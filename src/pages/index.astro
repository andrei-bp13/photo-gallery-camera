---
import { readdirSync, readFileSync, existsSync, mkdirSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { imageSize } from "image-size";
import sharp from "sharp";

// Any image dropped into public/photos/ is picked up automatically.
const photosDir = new URL("../../public/photos", import.meta.url);
const photoFiles = readdirSync(photosDir)
	.filter((name) => /\.(jpe?g|png|webp|gif)$/i.test(name));

// Pre-resize photos down to the actual pixel size they're displayed at, so the
// browser downloads much smaller files instead of full-resolution originals.
// Resized copies are cached on disk in public/photos-resized/ and only
// regenerated if missing.
const resizedDir = new URL("../../public/photos-resized/", import.meta.url);
if (!existsSync(resizedDir)) mkdirSync(resizedDir, { recursive: true });

// Re-encode photos as compressed WebP to cut file size — WITHOUT changing their
// pixel dimensions — so they look exactly as sharp/large as before but download faster.
async function compressedSrc(name: string): Promise<string> {
	const outName = `${name.replace(/\.[^.]+$/, "")}.webp`;
	const outPath = new URL(outName, resizedDir);
	if (!existsSync(outPath)) {
		await sharp(readFileSync(new URL(`./${name}`, `${photosDir}/`)))
			.webp({ quality: 70 })
			.toFile(fileURLToPath(outPath));
	}
	return `/photos-resized/${encodeURIComponent(outName)}`;
}

// Look up real dimensions so we can find landscape shots and group the gallery by orientation.
const sized = await Promise.all(photoFiles.map(async (name) => {
	const { width, height } = imageSize(readFileSync(new URL(`./${name}`, `${photosDir}/`)));
	const landscape = width > height;
	const compressed = await compressedSrc(name);
	return { src: compressed, slideSrc: compressed, fullSrc: `/photos/${encodeURIComponent(name)}`, landscape };
}));

// Shuffle (Fisher-Yates) so the gallery layout is different on every page load.
function shuffle<T>(arr: T[]): T[] {
	const out = [...arr];
	for (let i = out.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[out[i], out[j]] = [out[j], out[i]];
	}
	return out;
}

const gallery = shuffle(sized);
const slideshow = sized.filter((p) => p.landscape).map((p) => p.slideSrc);

// Group into rows: a landscape photo takes the space of two portraits,
// so each row holds either 4 portraits, or 2 portraits + 1 landscape.
type Row = { items: typeof gallery; cols: number };
const rows: Row[] = [];
let row: typeof gallery = [];
let used = 0;
for (const photo of gallery) {
	const cost = photo.landscape ? 2 : 1;
	if (used + cost > 4) {
		rows.push({ items: row, cols: used });
		row = [];
		used = 0;
	}
	row.push(photo);
	used += cost;
}
if (row.length) rows.push({ items: row, cols: used });
