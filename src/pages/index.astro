---
import { readdirSync, readFileSync } from "node:fs";
import { imageSize } from "image-size";

// Any image dropped into public/photos/ is picked up automatically.
const photosDir = new URL("../../public/photos", import.meta.url);
const photoFiles = readdirSync(photosDir)
	.filter((name) => /\.(jpe?g|png|webp|gif)$/i.test(name));

const tilts = [-3, 2, -2, 4, -1, 3];
const carousel = photoFiles.map((name, i) => ({
	src: `/photos/${encodeURIComponent(name)}`,
	tilt: tilts[i % tilts.length],
	big: i % 2 === 0,
	flip: i % 2 === 1,
}));

// Look up real dimensions so the gallery can group by orientation.
const gallery = photoFiles.map((name) => {
	const { width, height } = imageSize(readFileSync(new URL(`./${name}`, `${photosDir}/`)));
	return {
		src: `/photos/${encodeURIComponent(name)}`,
		landscape: width > height,
	};
});

// Group into rows: a landscape photo takes the space of two portraits,
// so each row holds either 4 portraits, or 2 portraits + 1 landscape.
type Row = { items: typeof gallery; cols: number };
const rows: Row[] = [];
let row: typeof gallery = [];
let used = 0;
for (const photo of gallery) {
	const cost = photo.landscape ? 2 : 1;
	if (used + cost > 4) {
		rows.push({ items: row, cols: used });
		row = [];
		used = 0;
	}
	row.push(photo);
	used += cost;
}
if (row.length) rows.push({ items: row, cols: used });

// Repeat the strip so the CSS animation can loop seamlessly with no gap.
const carouselLoop = [...carousel, ...carousel, ...carousel];
const loopFraction = (100 / 3).toFixed(4);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Photo Gallery</title>
	</head>
	<body>
		<header class="site-header">
			<span class="logo">PHOTOS</span>
		</header>

		<main>
			<section class="hero">
				<h1>Photo Gallery</h1>
				<p>A collection of moments, captured one frame at a time.</p>
			</section>

			<section class="carousel" aria-label="Featured photos">
				<div class="carousel-track" style={`--shift: -${loopFraction}%`}>
					{carouselLoop.map((photo) => (
						<div
							class:list={["cutout", photo.big ? "big" : "small", photo.flip ? "flip" : ""]}
							style={`--tilt: ${photo.tilt}deg`}
						>
							<img src={photo.src} alt="" loading="lazy" />
						</div>
					))}
				</div>
			</section>

			<section class="gallery">
				<h2>Gallery</h2>
				{rows.map((r) => (
					<div class="grid-row" style={`--cols: ${r.cols}`}>
						{r.items.map((photo) => (
							<button
								class:list={["grid-item", photo.landscape ? "landscape" : "portrait"]}
								data-full={photo.src}
							>
								<img src={photo.src} alt="" loading="lazy" />
							</button>
						))}
					</div>
				))}
			</section>
		</main>

		<div class="lightbox" id="lightbox">
			<img id="lightbox-img" src="" alt="" />
		</div>
	</body>
</html>

<script>
	const lightbox = document.getElementById("lightbox") as HTMLDivElement;
	const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;

	document.querySelectorAll<HTMLButtonElement>(".grid-item").forEach((item) => {
		item.addEventListener("click", () => {
			const full = item.dataset.full;
			if (!full) return;
			lightboxImg.src = full;
			lightbox.classList.add("open");
		});
	});

	lightbox.addEventListener("click", () => {
		lightbox.classList.remove("open");
		lightboxImg.src = "";
	});

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") {
			lightbox.classList.remove("open");
			lightboxImg.src = "";
		}
	});
</script>

<style is:global>
	:root {
		color-scheme: dark;
		font-family: "Segoe UI", system-ui, sans-serif;
	}
	* {
		box-sizing: border-box;
	}
	body {
		margin: 0;
		background: #1a1a1a;
		color: #f2f2f2;
	}
</style>

<style>
	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.5rem 3rem;
	}
	.logo {
		font-weight: 800;
		letter-spacing: 0.15em;
	}

	.hero {
		text-align: center;
		padding: 3rem 1.5rem 2rem;
	}
	.hero h1 {
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		margin: 0 0 0.5rem;
		font-weight: 800;
	}
	.hero p {
		color: #999;
		margin: 0;
	}

	/* --- Carousel --- */
	.carousel {
		overflow: hidden;
		padding: 3rem 0;
	}
	.carousel-track {
		display: flex;
		align-items: center;
		width: max-content;
		animation: scroll 320s linear infinite;
	}
	@keyframes scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(var(--shift));
		}
	}

	.cutout {
		flex: 0 0 auto;
		margin-right: -3.5rem;
		transform: rotate(var(--tilt));
		transition: transform 0.3s ease;
		/* brush-stroke cutout: the photo only shows through the painted shape */
		-webkit-mask-image: url("/brush-mask.png");
		mask-image: url("/brush-mask.png");
		-webkit-mask-size: 100% 100%;
		mask-size: 100% 100%;
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
	}
	.cutout.flip {
		-webkit-mask-image: url("/brush-mask.png");
		mask-image: url("/brush-mask.png");
		transform: rotate(var(--tilt)) scaleX(-1);
	}
	.cutout.big {
		width: 400px;
		height: 525px;
		z-index: 2;
	}
	.cutout.small {
		width: 288px;
		height: 400px;
		z-index: 1;
	}
	.cutout:hover {
		transform: rotate(0deg) scale(1.05);
		z-index: 3;
	}
	.cutout.flip:hover {
		transform: rotate(0deg) scaleX(-1) scale(1.05);
	}
	.cutout img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transform: scaleX(var(--img-flip, 1));
	}
	.cutout.flip img {
		--img-flip: -1;
	}

	/* --- Recent gallery grid --- */
	.gallery {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1.5rem 5rem;
	}
	.gallery h2 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}
	.grid-row {
		display: grid;
		grid-template-columns: repeat(var(--cols), 1fr);
		align-items: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}
	.grid-item {
		overflow: hidden;
		border-radius: 0.75rem;
		border: none;
		padding: 0;
		cursor: pointer;
		background: #2a2a2a;
	}
	.grid-item.portrait {
		grid-column: span 1;
		aspect-ratio: 3 / 4;
	}
	.grid-item.landscape {
		grid-column: span 2;
		aspect-ratio: 16 / 9;
	}
	.grid-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s ease;
	}
	.grid-item:hover img {
		transform: scale(1.05);
	}

	/* --- Lightbox --- */
	.lightbox {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.92);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.25s ease;
		z-index: 100;
		cursor: zoom-out;
	}
	.lightbox.open {
		opacity: 1;
		visibility: visible;
	}
	.lightbox img {
		max-width: 92vw;
		max-height: 92vh;
		object-fit: contain;
		border-radius: 0.5rem;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7);
	}
</style>
