</html>

<script>
	// --- Supernova stars: 10 independent dying-star flickers scattered over the page ---
	(() => {
		const field = document.getElementById("supernova-field");
		if (!field) return;

		const STAR_COUNT = 10;
		const LIFESPAN = 1; // seconds — exact total time visible (swell + hold + collapse)

		const styleSheet = document.createElement("style");
		document.head.appendChild(styleSheet);

		function rand(a: number, b: number) {
			return a + Math.random() * (b - a);
		}

		function spawn(index: number) {
			const star = document.createElement("div");
			star.className = "sn-star";
			star.innerHTML = `<span class="sn-glow"></span><span class="sn-core"></span>`;

			// Completely random position anywhere on the full page height.
			const x = rand(2, 98);
			const y = rand(2, 98);
			star.style.left = `${x}%`;
			star.style.top = `${y}%`;

			// Random pause (1–4s) before this star appears again — combined with
			// the fixed 1s lifespan to form one full cycle. Generating a bespoke
			// keyframe per spawn (with the active phase scaled to its share of
			// the cycle) keeps the swell→hold→collapse timing exact at 1s
			// regardless of how long the idle gap is.
			const idle = rand(1, 4);
			const cycle = LIFESPAN + idle;
			const activePct = (LIFESPAN / cycle) * 100;
			const swellEnd = activePct * 0.32;
			const holdEnd = activePct * 0.62;
			const collapseEnd = activePct;
			const name = `sn-life-${index}-${Math.random().toString(36).slice(2, 8)}`;

			styleSheet.sheet?.insertRule(`
				@keyframes ${name} {
					0%                       { transform: translate(-50%,-50%) scale(0.02); opacity: 0; }
					${swellEnd.toFixed(3)}%  { transform: translate(-50%,-50%) scale(1);    opacity: 1; }
					${holdEnd.toFixed(3)}%   { transform: translate(-50%,-50%) scale(1);    opacity: 1; }
					${collapseEnd.toFixed(3)}% { transform: translate(-50%,-50%) scale(0.02); opacity: 0; }
					100%                     { transform: translate(-50%,-50%) scale(0.02); opacity: 0; }
				}
			`, styleSheet.sheet.cssRules.length);

			star.style.animation = `${name} ${cycle}s ease-in-out infinite`;
			star.style.animationDelay = `${rand(0, cycle)}s`;

			field.appendChild(star);
		}

		for (let i = 0; i < STAR_COUNT; i++) spawn(i);
	})();

	// Filter bar: purely visual single-select toggle for now (no actual filtering yet)
	const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-btn"));
	filterBtns.forEach((btn) => {
		btn.addEventListener("click", () => {
			filterBtns.forEach((b) => b.classList.remove("active"));
			btn.classList.add("active");
		});
	});

	const lightbox = document.getElementById("lightbox") as HTMLDivElement;
	const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;

	// Discourage right-click save / drag-out of the fullscreen image.
	// Note: this can't truly prevent screenshots or determined users (browser tools,
	// dev console, OS screen capture always work) — it's a basic deterrent only.
	lightboxImg.addEventListener("contextmenu", (e) => e.preventDefault());
	lightboxImg.addEventListener("dragstart", (e) => e.preventDefault());
	lightboxImg.style.userSelect = "none";
	(lightboxImg.style as any).webkitUserSelect = "none";
	(lightboxImg.style as any).webkitTouchCallout = "none";

	const prevBtn = document.getElementById("lightbox-prev") as HTMLButtonElement;
	const nextBtn = document.getElementById("lightbox-next") as HTMLButtonElement;

	const galleryItems = Array.from(document.querySelectorAll<HTMLButtonElement>(".grid-item"));
	const photoSrcs = galleryItems.map((item) => item.dataset.full ?? "");
	let currentIndex = 0;

	function show(index: number) {
		currentIndex = (index + photoSrcs.length) % photoSrcs.length;
		lightboxImg.src = photoSrcs[currentIndex];
		lightbox.classList.add("open");
	}

	function close() {
		lightbox.classList.remove("open");
		lightboxImg.src = "";
	}

	galleryItems.forEach((item, i) => {
		item.addEventListener("click", () => show(i));
	});

	prevBtn.addEventListener("click", (e) => {
		e.stopPropagation();
		show(currentIndex - 1);
	});
	nextBtn.addEventListener("click", (e) => {
		e.stopPropagation();
		show(currentIndex + 1);
	});

	lightbox.addEventListener("click", close);

	document.addEventListener("keydown", (e) => {
		if (!lightbox.classList.contains("open")) return;
		if (e.key === "Escape") close();
		if (e.key === "ArrowLeft") show(currentIndex - 1);
		if (e.key === "ArrowRight") show(currentIndex + 1);
	});

	// Slideshow: blurred -> AF brackets blink (focusing) -> snap sharp -> hold -> fade out
	const slides = Array.from(document.querySelectorAll<HTMLDivElement>("#camera-screen .slide"));
	if (slides.length) {
		let current = 0;
		const TIMINGS = { blurHold: 500, focusing: 550, sharpHold: 1300, fadeOut: 350 };

		function runSlide(el: HTMLDivElement) {
			el.classList.remove("sharp", "focusing");
			el.classList.add("active");
			// phase 1: shows up blurred
			setTimeout(() => {
				// phase 2: AF brackets blink while "focusing"
				el.classList.add("focusing");
				setTimeout(() => {
					// phase 3: focus snaps — brackets gone, image sharpens (the "shutter" moment)
					el.classList.remove("focusing");
					el.classList.add("sharp");
					setTimeout(() => {
						// phase 4: fade out, move to next
						el.classList.remove("active");
						setTimeout(() => {
							current = (current + 1) % slides.length;
							runSlide(slides[current]);
						}, TIMINGS.fadeOut);
					}, TIMINGS.sharpHold);
				}, TIMINGS.focusing);
			}, TIMINGS.blurHold);
		}

		runSlide(slides[current]);
	}
</script>

<style is:global>
	:root {
		color-scheme: dark;
		font-family: "Segoe UI", system-ui, sans-serif;
	}
	* {
		box-sizing: border-box;
	}
	body {
		position: relative;
		margin: 0;
		background: #1a1a1a;
		color: #f2f2f2;
	}

	/* ── Supernova stars ─────────────────────────────────────── */
	.supernova-field {
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}
	.sn-star {
		position: absolute;
		transform: translate(-50%, -50%) scale(0.02);
		opacity: 0;
		pointer-events: none;
		will-change: transform, opacity;
	}
	/* glow disc behind the core */
	.sn-glow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 48px;
		height: 48px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(200, 230, 255, 0.85) 0%, rgba(140, 180, 255, 0.5) 30%, rgba(100, 120, 255, 0.12) 65%, transparent 100%);
		filter: blur(4px);
	}
	/* 4-point sparkle core via clip-path */
	.sn-core {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 16px;
		height: 16px;
		/* 4-pointed star / sparkle cross shape */
		clip-path: polygon(
			50% 0%,  56% 44%,
			100% 50%, 56% 56%,
			50% 100%, 44% 56%,
			0% 50%,  44% 44%
		);
		background: radial-gradient(circle at 50% 50%, #ffffff 0%, #c8e8ff 55%, #7ab8ff 100%);
	}
</style>

<style>
	.site-header {
		position: relative;
		z-index: 10;
		display: flex;
		align-items: center;
		min-height: 64px;
		padding: 0 2rem;
		background: #111111;
		border-bottom: 1px solid #333333;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.36rem;
		padding-left: 30px;
	}
	.brand-icon {
		width: 78px;
		height: 78px;
		flex-shrink: 0;
	}
	.brand-text {
		display: flex;
		flex-direction: column;
		justify-content: center;
		line-height: 1.05;
	}
	.brand-line {
		font-family: "Orbitron", sans-serif;
		font-weight: 700;
	}
	.brand-orbit {
		font-size: 17px;
		letter-spacing: 4px;
		color: #c9a84c;
	}
	.brand-dust {
		font-size: 15px;
		letter-spacing: 7px;
		color: rgba(201, 168, 76, 0.7);
	}
	.center-tagline {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		font-family: "Great Vibes", cursive;
		font-weight: 400;
		font-size: 1.5rem;
		letter-spacing: 0.04em;
		color: #999;
		white-space: nowrap;
	}
	@media (max-width: 640px) {
		.center-tagline {
			display: none;
		}
	}

	/* --- Camera + slideshow --- */
	.camera-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 1.5rem 1.5rem 4rem;
	}
	.camera {
		position: relative;
		width: min(90vw, 720px);
	}
	.camera-outline {
		display: block;
		width: 100%;
		height: auto;
		position: relative;
		z-index: 2;
		/* outline extracted with a transparent background, so the page's
		   dark gray shows through instead of the original pure black */
	}
	/* Sits inside the smaller inner rectangle of the LCD, not the outer bezel */
	.camera-screen {
		position: absolute;
		left: 30.3%;
		top: 43.7%;
		width: 31.2%;
		height: 42.4%;
		overflow: hidden;
		border-radius: 2px;
		z-index: 1;
		background: #000;
	}
	/* Each slide goes through: fade in (blurred) -> AF brackets blink while
	   focusing -> snap to sharp (brackets gone), like taking a photo. */
	.slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.35s ease;
	}
	.slide.active {
		opacity: 1;
	}
	.slide img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: blur(7px);
		transition: filter 0.2s ease-out;
	}
	.slide.sharp img {
		filter: blur(0);
	}
	.af-grid {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		display: grid;
		grid-template-columns: repeat(3, 10px);
		grid-template-rows: repeat(3, 10px);
		gap: 4px;
	}
	.af-cell {
		width: 10px;
		height: 10px;
		border: 2px solid #59e878;
		box-shadow: 0 0 6px rgba(89, 232, 120, 0.6);
		opacity: 0;
	}
	.slide.focusing .af-cell {
		animation: af-blink 0.16s steps(1, end) 3;
	}
	@keyframes af-blink {
		0%, 49% { opacity: 1; }
		50%, 100% { opacity: 0.1; }
	}

	/* --- Recent gallery grid --- */
	.gallery {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1.5rem 5rem;
	}
	.gallery h2 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}
	.filter-bar {
		display: flex;
		justify-content: space-evenly;
		align-items: center;
		margin-bottom: 2rem;
		padding: 0 1rem;
	}
	.filter-btn {
		background: none;
		border: none;
		cursor: pointer;
		color: #888;
		padding: 0.4rem;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		transition: color 0.2s ease;
	}
	.filter-btn:hover {
		color: #bbb;
	}
	.filter-btn.active {
