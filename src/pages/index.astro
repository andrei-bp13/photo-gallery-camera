<script>

	// ── Filter setup ─────────────────────────────────────────────────────────
	const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-btn"));
	const dieBtn = filterBtns.find(b => b.dataset.tag === "random")!;
	// non-random buttons in DOM order (left → right, excluding die)
	const regularBtns = filterBtns.filter(b => b.dataset.tag !== "random");

	// filename → string[] (loaded from the gallery snapshot / D1)
	const tagMap = new Map<string, string[]>();
	let tagsLoaded = false;

	// ── Gallery items ─────────────────────────────────────────────────────────
	let galleryItems = Array.from(document.querySelectorAll<HTMLButtonElement>(".grid-item"));
	let photoSrcs: string[] = [];     // fullscreen display URLs (Cloudflare-resized)
	let photoFulls: string[] = [];    // original R2 URLs, used as a fallback
	let photoNames: string[] = [];    // filenames, used to build the "enhance" URL
	const gallerySection = document.querySelector<HTMLElement>(".gallery")!;

	const R2_BASE = "https://pub-0d81359dcf6343cba33754dd0dad97fc.r2.dev";
	const r2 = (name: string) => `${R2_BASE}/${encodeURIComponent(name)}`;

	// Cloudflare Image Resizing (Transformations enabled on orbitdust.art).
	const SITE_BASE = "https://orbitdust.art";
	const CF_WIDTHS = [400, 600, 900, 1280];
	const cfImg = (name: string, w: number) =>
		`${SITE_BASE}/cdn-cgi/image/width=${w},quality=80,format=auto/${r2(name)}`;
	const cfSrcset = (name: string) => CF_WIDTHS.map((w) => `${cfImg(name, w)} ${w}w`).join(", ");
	const PORTRAIT_SIZES = "(max-width: 640px) 25vw, 285px";
	const LANDSCAPE_SIZES = "(max-width: 640px) 50vw, 575px";

	function clientShuffle<T>(arr: T[]): T[] {
		const out = [...arr];
		for (let i = out.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[out[i], out[j]] = [out[j], out[i]];
		}
		return out;
	}

	// ── Lazy-load via IntersectionObserver (avoids browser evicting images on scroll) ──
	const lazyObs = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (!entry.isIntersecting) return;
			const img = entry.target as HTMLImageElement;
			if (img.dataset.src) img.src = img.dataset.src;
			if (img.dataset.srcset) img.srcset = img.dataset.srcset;
			lazyObs.unobserve(img);
		});
	}, { rootMargin: '800px 0px' });

	// ── Reveal animation: fade + slide-up each item as it scrolls into view ──
	// Triggers at the actual viewport (not 800px ahead like the loader), waits for
	// the image to finish loading, and staggers items that appear together so each
	// row cascades left-to-right.
	const revealObs = new IntersectionObserver((entries) => {
		let stagger = 0;
		entries.forEach(entry => {
			if (!entry.isIntersecting) return;
			const item = entry.target as HTMLElement;
			revealObs.unobserve(item);
			const delay = stagger * 70;
			stagger++;
			const img = item.querySelector('img');
			const reveal = () => {
				item.style.transitionDelay = delay + 'ms';
				item.classList.add('revealed');
			};
			if (img && img.complete && img.naturalWidth > 0) {
				reveal();
			} else if (img) {
				img.addEventListener('load', reveal, { once: true });
				img.addEventListener('error', reveal, { once: true });
			} else {
				reveal();
			}
		});
	}, { rootMargin: '0px 0px -5% 0px', threshold: 0.01 });

	// Build a gallery grid-item button from a snapshot entry { name, landscape }.
	function buildGridItem(photo: { name: string; landscape: boolean }): HTMLButtonElement {
		const btn = document.createElement("button");
		btn.className = `grid-item ${photo.landscape ? "landscape" : "portrait"}`;
		btn.dataset.full = r2(photo.name);
		btn.dataset.filename = photo.name;
		const img = document.createElement("img");
		img.src = "";
		img.dataset.src = r2(photo.name);
		img.dataset.srcset = cfSrcset(photo.name);
		img.sizes = photo.landscape ? LANDSCAPE_SIZES : PORTRAIT_SIZES;
		img.width = photo.landscape ? 800 : 600;
		img.height = photo.landscape ? 450 : 800;
		img.alt = "";
		img.draggable = false;
		img.setAttribute("onerror", "this.srcset=''");
		img.setAttribute("oncontextmenu", "return false");
		img.setAttribute("ondragstart", "return false");
		btn.appendChild(img);
		return btn;
	}

	// (Re)bind lazy-load + reveal + lightbox click to the current galleryItems and
	// rebuild the photoSrcs index. Runs on first load and after a snapshot refresh.
	function wireGalleryItems() {
		// Fullscreen shows a Cloudflare-resized 1600px variant (≈80KB vs the ~360KB
		// original); the original stays as a per-image fallback if a transform fails.
		photoSrcs = galleryItems.map((item) => cfImg(item.dataset.filename ?? "", 1600));
		photoFulls = galleryItems.map((item) => item.dataset.full ?? "");
		photoNames = galleryItems.map((item) => item.dataset.filename ?? "");
		galleryItems.forEach((item, i) => {
			const img = item.querySelector("img");
			if (img) lazyObs.observe(img);
			revealObs.observe(item);
			item.addEventListener("click", () => show(i));
		});
	}

	// Replace the whole gallery with photos from the live snapshot, preserving the
	// row layout + reveal animation. Keeps the currently-active filter applied.
	function rebuildGallery(photos: { name: string; landscape: boolean; tags: string[] }[]) {
		tagMap.clear();
		photos.forEach(p => tagMap.set(p.name, p.tags || []));
		tagsLoaded = true;
		galleryItems.forEach(item => {
			const img = item.querySelector("img");
			if (img) lazyObs.unobserve(img);
			revealObs.unobserve(item);
		});
		galleryItems = clientShuffle(photos).map(buildGridItem);
		wireGalleryItems();
		const active = filterBtns.find(b => b.classList.contains("active"));
		const tag = active && active.dataset.tag !== "random" ? (active.dataset.tag ?? "all") : "all";
		applyFilter(tag);
	}

	function packIntoRows(items: HTMLButtonElement[]) {
		const result: { items: HTMLButtonElement[]; cols: number }[] = [];
		let i = 0;
		let lLeft = true;
		while (i < items.length) {
			const chunk: HTMLButtonElement[] = [];
			let cols = 0;
			while (i < items.length) {
				const cost = items[i].classList.contains("landscape") ? 2 : 1;
				if (cols + cost > 4) break;
				chunk.push(items[i]);
				cols += cost;
				i++;
			}
			const ls = chunk.filter(a => a.classList.contains("landscape"));
			const ps = chunk.filter(a => !a.classList.contains("landscape"));
			let arranged: HTMLButtonElement[];
			if (ls.length > 0 && ps.length > 0) {
				arranged = lLeft ? [...ls, ...ps] : [...ps, ...ls];
				lLeft = !lLeft;
			} else {
				arranged = [...ls, ...ps];
			}
			result.push({ items: arranged, cols });
		}
		return result;
	}

	function applyFilter(tag: string) {
		const visible = (tag === "all" || !tagsLoaded)
			? galleryItems
			: galleryItems.filter(item => {
				const tags = tagMap.get(item.dataset.filename ?? "") ?? [];
				return tags.includes(tag);
			});

		gallerySection.querySelectorAll<HTMLElement>(".grid-row").forEach(r => r.remove());

		const frag = document.createDocumentFragment();
		for (const { items, cols } of packIntoRows(visible)) {
			const div = document.createElement("div");
			div.className = "grid-row";
			div.style.setProperty("--cols", String(cols));
			items.forEach(item => div.appendChild(item));
			frag.appendChild(div);
		}
		gallerySection.appendChild(frag);
	}

	// ── Die face definitions ──────────────────────────────────────────────────
	const DIE_FACES: [number, number][][] = [
		[[12, 12]],
		[[8.5, 8.5], [15.5, 15.5]],
		[[8.5, 8.5], [12, 12], [15.5, 15.5]],
		[[8.5, 8.5], [15.5, 8.5], [8.5, 15.5], [15.5, 15.5]],
		[[8.5, 8.5], [15.5, 8.5], [12, 12], [8.5, 15.5], [15.5, 15.5]],
		[[8.5, 8], [15.5, 8], [8.5, 12], [15.5, 12], [8.5, 16], [15.5, 16]],
	];

	function setDieFace(face: number) {
		const svg = dieBtn.querySelector("svg")!;
		svg.querySelectorAll("circle").forEach(c => c.remove());
		const frag = document.createDocumentFragment();
		DIE_FACES[face].forEach(([cx, cy]) => {
			const c = document.createElementNS("http://www.w3.org/2000/svg", "circle");
			c.setAttribute("cx", String(cx));
			c.setAttribute("cy", String(cy));
			c.setAttribute("r", "1.1");
			c.setAttribute("fill", "currentColor");
			c.setAttribute("stroke", "none");
			frag.appendChild(c);
		});
		svg.appendChild(frag);
	}

	function randomFace() { return Math.floor(Math.random() * 6); }

	// ── Icon hover: finish animation cycle before stopping ───────────────────
	const ANIM_SENTINEL: Record<string, string> = {
		all:       'rect',
		people:    '.wave-arm',
		streetart: '.spray-lines',
		nature:    'path',
		animals:   '.cat-head',
		objects:   '.diamond-path',
		buildings: '.w1',
	};
	regularBtns.forEach(btn => {
		const tag = btn.dataset.tag ?? '';
		const sel = ANIM_SENTINEL[tag];
		if (!sel) return;
		const sentinel = btn.querySelector(sel) as Element | null;
		let hovered = false;
		btn.addEventListener('mouseenter', () => {
			hovered = true;
			btn.classList.add('playing');
		});
		btn.addEventListener('mouseleave', () => {
			hovered = false;
		});
		sentinel?.addEventListener('animationiteration', () => {
			if (!hovered) btn.classList.remove('playing');
		});
	});

	// ── Die hover: cycle faces while hovering ────────────────────────────────
	let dieHoverInterval: ReturnType<typeof setInterval> | null = null;
	dieBtn.addEventListener('mouseenter', () => {
		setDieFace(randomFace());
		dieHoverInterval = setInterval(() => setDieFace(randomFace()), 200);
	});
	dieBtn.addEventListener('mouseleave', () => {
		if (dieHoverInterval !== null) { clearInterval(dieHoverInterval); dieHoverInterval = null; }
	});

	// ── Die animation ─────────────────────────────────────────────────────────
	let dieRunning = false;

	function sleep(ms: number) { return new Promise<void>(r => setTimeout(r, ms)); }

	function setOnlyActive(btn: HTMLButtonElement | null) {
		filterBtns.forEach(b => b.classList.remove("active"));
		btn?.classList.add("active");
	}

	// Trigger the hover animation for a regular button for one cycle
	function playIconOnce(btn: HTMLButtonElement) {
		btn.classList.add('playing');
		const tag = btn.dataset.tag ?? '';
		const sel = ANIM_SENTINEL[tag];
		if (!sel) return;
		const sentinel = btn.querySelector(sel) as Element | null;
		const onIteration = () => {
			btn.classList.remove('playing');
			sentinel?.removeEventListener('animationiteration', onIteration);
		};
		sentinel?.addEventListener('animationiteration', onIteration);
	}

	async function runDieAnimation() {
		if (dieRunning) return;
		dieRunning = true;
		if (dieHoverInterval !== null) { clearInterval(dieHoverInterval); dieHoverInterval = null; }

		const N = 50 + Math.floor(Math.random() * 11); // 50–60
		// Pick winner randomly upfront — independent of where the ping-pong lands
		const winner = regularBtns[Math.floor(Math.random() * regularBtns.length)];
		// Ease-out shape: ratio 1→25 (quadratic). Normalize so total = 3000ms exactly.
		const rawDelays = Array.from({ length: N }, (_, i) => 1 + 24 * Math.pow(i / (N - 1), 2));
		const scale = 3000 / rawDelays.reduce((s, d) => s + d, 0);
		const spinDelay = (i: number) => rawDelays[i] * scale;

		setOnlyActive(dieBtn);

		// ── Phase 1: ping-pong bounce (visual only) ───────────────────────────
		let pos = 0;
		let dir = 1;
		for (let i = 0; i < N; i++) {
			filterBtns.forEach(b => { if (b !== dieBtn) b.classList.remove("active"); });
			regularBtns[pos].classList.add("active");
			dieBtn.classList.add("active");
			setDieFace(randomFace());
			await sleep(spinDelay(i));
			pos += dir;
			if (pos >= regularBtns.length) { pos -= 2; dir = -1; }
			else if (pos < 0) { pos = 1; dir = 1; }
		}

		// ── Phase 2: closing sweep — die → winner ────────────────────────────
		const SWEEP_DELAY = 80;
		filterBtns.forEach(b => b.classList.remove("active"));
		dieBtn.classList.add("active");
		await sleep(SWEEP_DELAY);

		for (const btn of [...regularBtns].reverse()) {
			filterBtns.forEach(b => b.classList.remove("active"));
			btn.classList.add("active");
			if (btn === winner) break;
			await sleep(SWEEP_DELAY);
		}
		await sleep(SWEEP_DELAY);

		// ── Phase 3: sweep back from winner to all (no die) ───────────────────
		const winnerIdx = regularBtns.indexOf(winner);
		for (let i = winnerIdx; i >= 0; i--) {
			filterBtns.forEach(b => b.classList.remove("active"));
			regularBtns[i].classList.add("active");
			await sleep(SWEEP_DELAY);
		}

		// ── End: activate selected category, play its icon animation ─────────
		filterBtns.forEach(b => b.classList.remove("active"));
		winner.classList.add("active");
		applyFilter(winner.dataset.tag ?? "all");
		playIconOnce(winner);
		dieRunning = false;
	}

	// ── Filter click handlers ─────────────────────────────────────────────────
	filterBtns.forEach(btn => {
		btn.addEventListener("click", () => {
			if (btn.dataset.tag === "random") {
				runDieAnimation();
				return;
			}
			if (dieRunning) return;
			setOnlyActive(btn);
			applyFilter(btn.dataset.tag ?? "all");
		});
	});

	const lightbox = document.getElementById("lightbox") as HTMLDivElement;
	const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;

	// Discourage right-click save / drag-out of the fullscreen image.
	// Note: this can't truly prevent screenshots or determined users (browser tools,
	// dev console, OS screen capture always work) — it's a basic deterrent only.
	lightboxImg.addEventListener("contextmenu", (e) => e.preventDefault());
	lightboxImg.addEventListener("dragstart", (e) => e.preventDefault());
	lightboxImg.style.userSelect = "none";
	(lightboxImg.style as any).webkitUserSelect = "none";
	(lightboxImg.style as any).webkitTouchCallout = "none";

	// If the Cloudflare-resized variant fails, fall back to the original R2 image.
	// Ignore the deliberate src="" on close (and never act while closed), otherwise
	// it would reload the previous photo and flash it on the next open.
	lightboxImg.addEventListener("error", () => {
		if (!lightbox.classList.contains("open")) return;
		const cur = lightboxImg.getAttribute("src") || "";
		if (!cur.startsWith("http")) return;
		const full = photoFulls[currentIndex];
		if (full && lightboxImg.src !== full) lightboxImg.src = full;
	});

	const prevBtn = document.getElementById("lightbox-prev") as HTMLButtonElement;
	const nextBtn = document.getElementById("lightbox-next") as HTMLButtonElement;

	let currentIndex = 0;

	// Lock background scroll while the lightbox is open; compensate for the
	// scrollbar width so the page behind doesn't shift when it disappears.
	function lockScroll() {
		const sw = window.innerWidth - document.documentElement.clientWidth;
		document.documentElement.style.overflow = "hidden";
		if (sw > 0) document.documentElement.style.paddingRight = sw + "px";
	}
	function unlockScroll() {
		document.documentElement.style.overflow = "";
		document.documentElement.style.paddingRight = "";
	}

	// Warm (and pre-decode) the neighbouring photos so navigation is instant.
	function preloadAdjacent() {
		[currentIndex + 1, currentIndex - 1].forEach((i) => {
			const im = new Image();
			im.src = photoSrcs[(i + photoSrcs.length) % photoSrcs.length];
			im.decode?.().catch(() => {});
		});
	}

	// Swap in an already-decoded src and play the slide-in. Done synchronously so
	// the browser never repaints the previous image at centre during the swap.
	function applyImage(src: string, direction: number) {
		lightboxImg.style.transition = "";
		lightboxImg.style.transform = "";
		lightboxImg.style.opacity = "";
		lightboxImg.src = src;
		if (direction !== 0) {
			lightboxImg.classList.remove("slide-r", "slide-l");
			void lightboxImg.offsetWidth;   // force reflow so the animation restarts
			lightboxImg.classList.add(direction > 0 ? "slide-r" : "slide-l");
		}
	}

	// direction: +1 = next (new photo slides in from the right), -1 = prev (from
	// the left), 0 = opening from the gallery (no slide).
	function show(index: number, direction = 0) {
		const wasOpen = lightbox.classList.contains("open");
		currentIndex = (index + photoSrcs.length) % photoSrcs.length;
		lightbox.classList.add("open");
		lightbox.classList.remove("enhancing");   // changing photo cancels any enhance
		if (!wasOpen) lockScroll();
		const idx = currentIndex;
		const src = photoSrcs[idx];

		if (direction === 0) {
			// Opening: show the gallery's already-loaded thumbnail instantly (no blank
			// wait while the full AVIF downloads), then quietly upgrade to the full
			// display image once it's decoded. Setting this photo's thumb right away
			// also means the previous photo is never shown.
			const thumb = galleryItems[idx]?.querySelector("img")?.currentSrc || "";
			applyImage(thumb || src, 0);
			if (thumb && thumb !== src) {
				const pre = new Image();
				pre.src = src;
				const upgrade = () => {
					if (idx === currentIndex && lightbox.classList.contains("open")) lightboxImg.src = src;
				};
				if (pre.decode) pre.decode().then(upgrade).catch(() => { pre.onload = upgrade; });
				else pre.onload = upgrade;
			}
		} else {
			// Navigating: neighbours are preloaded, so decode first to avoid any flash
			// of the previous photo during the swap.
			const pre = new Image();
			pre.src = src;
			const reveal = () => { if (idx === currentIndex) applyImage(src, direction); };
			const waitLoad = () => { if (pre.complete) reveal(); else { pre.onload = reveal; pre.onerror = reveal; } };
			if (pre.decode) pre.decode().then(reveal).catch(waitLoad);
			else waitLoad();
		}
		preloadAdjacent();
	}

	function close() {
		lightbox.classList.remove("open");
		lightbox.classList.remove("enhancing");
		lightboxImg.src = "";
		lightboxImg.classList.remove("slide-r", "slide-l");
		lightboxImg.style.transform = "";
		lightboxImg.style.opacity = "";
		lightboxImg.style.transition = "";
		unlockScroll();
	}

	// NOTE: gallery wiring (which triggers the reveal animation) is intentionally
	// deferred to the bootstrap below. If we revealed the static gallery now and a
	// snapshot then rebuilt it, the gallery would flash (appear, wipe, reappear).
	// Keeping it hidden until the snapshot resolves makes the rebuild invisible.

	prevBtn.addEventListener("click", (e) => {
		e.stopPropagation();
		show(currentIndex - 1, -1);
	});
	nextBtn.addEventListener("click", (e) => {
		e.stopPropagation();
		show(currentIndex + 1, 1);
	});

	// ── "Enhance": load the full-resolution original, with a blur + loading message ──
	const enhanceBtn = document.getElementById("lightbox-enhance") as HTMLButtonElement;
	const enhanceOverlay = document.getElementById("enhance-overlay") as HTMLElement;
	const enhanceText = document.getElementById("enhance-text") as HTMLElement;
	const ENHANCE_MSGS = [
		"downloading RAM...",
		"going quantum...",
		"engaging warp drive...",
		"yelling at hamsters...",
		"starting AI revolution...",
	];

	// Size the overlay to the photo's rendered box so the text stays within the picture.
	function positionEnhanceOverlay() {
		const r = lightboxImg.getBoundingClientRect();
		enhanceOverlay.style.left = r.left + "px";
		enhanceOverlay.style.top = r.top + "px";
		enhanceOverlay.style.width = r.width + "px";
		enhanceOverlay.style.height = r.height + "px";
	}

	// Biggest resolution the source offers (2400px), re-encoded to a light AVIF by
	// Cloudflare. (An earlier screen-width cap was dropped: on phones the 1600px
	// display already exceeds the screen, so the cap made the button a no-op.)
	function enhanceSrc(name: string) {
		return cfImg(name, 2400);
	}

	enhanceBtn.addEventListener("click", (e) => {
		e.stopPropagation();
		const idx = currentIndex;
		const name = photoNames[idx];
		const full = name ? enhanceSrc(name) : "";
		if (!full || lightboxImg.src === full) return;   // nothing bigger to load for this screen
		enhanceText.textContent = ENHANCE_MSGS[Math.floor(Math.random() * ENHANCE_MSGS.length)];
		positionEnhanceOverlay();
		lightbox.classList.add("enhancing");             // blur the current photo + show message
		const pre = new Image();
		pre.src = full;
		const done = () => {
			if (idx !== currentIndex) { lightbox.classList.remove("enhancing"); return; }
			lightboxImg.src = full;                       // swap to full res (still blurred)…
			lightbox.classList.remove("enhancing");       // …then blur + text fade out, revealing it sharp
		};
		if (pre.decode) pre.decode().then(done).catch(() => { if (pre.complete) done(); else { pre.onload = done; pre.onerror = done; } });
		else { pre.onload = done; pre.onerror = done; if (pre.complete) done(); }
	});

	// Tap the backdrop/image to close — unless the tap was actually a swipe.
	let suppressClick = false;
	lightbox.addEventListener("click", () => {
		if (suppressClick) { suppressClick = false; return; }
		close();
	});

	// Drag-to-navigate: the image tracks the finger; release past 50% of the screen
	// width commits to the next/prev photo, otherwise it snaps back. Uses only a
	// GPU-composited transform/opacity, so it stays cheap.
	let dragStartX = 0, dragStartY = 0, dragDx = 0;
	let dragging = false, dragHorizontal = false;

	function commitSwipe(dir: number) {
		const w = window.innerWidth;
		// finish sliding the current image off in the drag direction, then swap in the neighbour
		lightboxImg.style.transition = "transform 0.16s ease-out, opacity 0.16s ease-out";
		lightboxImg.style.transform = `translateX(${dir > 0 ? -w : w}px)`;
		lightboxImg.style.opacity = "0";
		const onDone = () => {
			lightboxImg.removeEventListener("transitionend", onDone);
			// Leave the (now off-screen, opacity 0) old image as-is; show() decodes the
			// new image then swaps it in via applyImage, so the old one never reappears.
			show(currentIndex + dir, dir);
		};
		lightboxImg.addEventListener("transitionend", onDone, { once: true });
	}

	lightbox.addEventListener("touchstart", (e) => {
		if (e.touches.length !== 1) return;
		suppressClick = false;
		dragging = true;
		dragHorizontal = false;
		dragDx = 0;
		dragStartX = e.touches[0].clientX;
		dragStartY = e.touches[0].clientY;
		lightboxImg.style.transition = "none";   // track the finger 1:1
		lightboxImg.classList.remove("slide-r", "slide-l");
	}, { passive: true });

	lightbox.addEventListener("touchmove", (e) => {
		if (!dragging) return;
		const dx = e.touches[0].clientX - dragStartX;
		const dy = e.touches[0].clientY - dragStartY;
		if (!dragHorizontal) {
			if (Math.abs(dx) < 8 && Math.abs(dy) < 8) return;      // wait until intent is clear
			if (Math.abs(dx) <= Math.abs(dy)) {                    // vertical → not a swipe
				dragging = false;
				lightboxImg.style.transition = "";
				return;
			}
			dragHorizontal = true;
		}
		e.preventDefault();   // horizontal drag: suppress scroll / back-gesture
		dragDx = dx;
		const w = window.innerWidth;
		lightboxImg.style.transform = `translateX(${dx}px)`;
		lightboxImg.style.opacity = String(Math.max(0.4, 1 - Math.abs(dx) / w));
	}, { passive: false });

	lightbox.addEventListener("touchend", () => {
		if (!dragging) return;
		dragging = false;
		if (!dragHorizontal) return;
		suppressClick = true;   // a drag shouldn't also close the lightbox
		const w = window.innerWidth;
		if (Math.abs(dragDx) > w * 0.4) {
			commitSwipe(dragDx < 0 ? 1 : -1);
		} else {
			// snap back to center
			lightboxImg.style.transition = "transform 0.18s ease-out, opacity 0.18s ease-out";
			lightboxImg.style.transform = "";
			lightboxImg.style.opacity = "";
		}
	}, { passive: true });

	document.addEventListener("keydown", (e) => {
		if (!lightbox.classList.contains("open")) return;
		if (e.key === "Escape") close();
		if (e.key === "ArrowLeft") show(currentIndex - 1, -1);
		if (e.key === "ArrowRight") show(currentIndex + 1, 1);
	});

	// Slideshow: blurred -> AF brackets blink (focusing) -> snap sharp -> hold -> fade out
	const cameraScreen = document.getElementById("camera-screen");
	const SLIDE_TIMINGS = { blurHold: 500, focusing: 550, sharpHold: 1300, fadeOut: 350 };
	let slideGen = 0;   // bumped on each (re)start to stop any prior recursive chain

	// Just-in-time image loading: only the visible + next slide are fetched, instead of
	// all landscape images at once on page load. The blur + AF-square effects are pure
	// CSS on the slide element, so deferring the image src does not affect them.
	function loadSlide(slides: HTMLDivElement[], i: number) {
		const img = slides[i]?.querySelector("img");
		if (img && !img.getAttribute("src") && img.dataset.thumb) {
			img.src = img.dataset.thumb;
		}
	}

	function startSlideshow() {
		if (!cameraScreen) return;
		const slides = Array.from(cameraScreen.querySelectorAll<HTMLDivElement>(".slide"));
		if (!slides.length) return;
		const gen = ++slideGen;
		let current = 0;

		loadSlide(slides, 0);
		loadSlide(slides, 1 % slides.length);

		function runSlide(el: HTMLDivElement) {
			if (gen !== slideGen) return;
			el.classList.remove("sharp", "focusing");
			el.classList.add("active");
			// preload the next image now (~2.7s before it's shown), so it's ready in time
			loadSlide(slides, (current + 1) % slides.length);
			// phase 1: shows up blurred
			setTimeout(() => {
				if (gen !== slideGen) return;
				// phase 2: AF brackets blink while "focusing"
				el.classList.add("focusing");
				setTimeout(() => {
					if (gen !== slideGen) return;
					// phase 3: focus snaps — brackets gone, image sharpens (the "shutter" moment)
					el.classList.remove("focusing");
					el.classList.add("sharp");
					setTimeout(() => {
						if (gen !== slideGen) return;
						// phase 4: fade out, move to next
						el.classList.remove("active");
						setTimeout(() => {
							if (gen !== slideGen) return;
							current = (current + 1) % slides.length;
							runSlide(slides[current]);
						}, SLIDE_TIMINGS.fadeOut);
					}, SLIDE_TIMINGS.sharpHold);
				}, SLIDE_TIMINGS.focusing);
			}, SLIDE_TIMINGS.blurHold);
		}

		runSlide(slides[current]);
	}

	// Rebuild the camera slides from the live snapshot's landscape photos (randomized).
	function rebuildSlideshow(srcs: { thumb: string; full: string }[]) {
		if (!cameraScreen) return;
		const frag = document.createDocumentFragment();
		srcs.forEach((s, i) => {
			const slide = document.createElement("div");
			slide.className = "slide";
			slide.dataset.index = String(i);
			const img = document.createElement("img");
			img.dataset.thumb = s.thumb;
			img.dataset.full = s.full;
			img.alt = "";
			img.draggable = false;
			img.setAttribute("onerror", "if(this.dataset.full){var f=this.dataset.full;this.dataset.full='';this.src=f}");
			img.setAttribute("oncontextmenu", "return false");
			img.setAttribute("ondragstart", "return false");
			const afGrid = document.createElement("span");
			afGrid.className = "af-grid";
			for (let k = 0; k < 9; k++) {
				const cell = document.createElement("span");
				cell.className = "af-cell";
				afGrid.appendChild(cell);
			}
			slide.appendChild(img);
			slide.appendChild(afGrid);
			frag.appendChild(slide);
		});
		cameraScreen.replaceChildren(frag);
		startSlideshow();
	}

	startSlideshow();

	// ── Sync gallery + slideshow with the live snapshot (regenerated by the admin
	//    "Clear cache + refresh database" button). Falls back to the static build. ──

	// Filename set the server rendered the slideshow with (rebuild only if it changed).
	const ssrSlideKey = Array.from(document.querySelectorAll<HTMLImageElement>("#camera-screen .slide img"))
		.map(img => decodeURIComponent((img.dataset.full || "").split("/").pop() || ""))
		.sort().join("|");

	(async () => {
		try {
			const res = await fetch("/api/gallery", { cache: "no-cache" });
			if (res.ok) {
				const photos = await res.json() as { name: string; landscape: boolean; tags: string[] }[];
				if (Array.isArray(photos) && photos.length) {
					tagMap.clear();
					photos.forEach(p => tagMap.set(p.name, p.tags || []));
					tagsLoaded = true;

					// Always rebuild so the gallery gets a fresh random order on every
					// load (and picks up any added/removed photos). The gallery stays
					// hidden until this completes, so there's no flash.
					rebuildGallery(photos);

					// Slideshow: only rebuild if the landscape set actually changed.
					const snapSlideKey = photos.filter(p => p.landscape).map(p => p.name).sort().join("|");
					if (snapSlideKey !== ssrSlideKey) {
						rebuildSlideshow(
							clientShuffle(photos.filter(p => p.landscape))
								.map(p => ({ thumb: cfImg(p.name, 600), full: r2(p.name) }))
						);
					}
					return;
				}
			}
		} catch {}
		// No snapshot yet — reveal the static gallery and load tags so filtering works.
		wireGalleryItems();
		try {
			const res = await fetch("/api/tags");
			if (!res.ok) return;
			const { photos } = await res.json();
			(photos as { filename: string; tags: string[] }[]).forEach(p => tagMap.set(p.filename, p.tags || []));
			tagsLoaded = true;
		} catch {}
	})();
</script>

