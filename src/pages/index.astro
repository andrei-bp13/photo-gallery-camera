import photosManifest from "../photos-manifest.json";

const R2_BASE = "https://pub-0d81359dcf6343cba33754dd0dad97fc.r2.dev";

// Cloudflare Image Resizing: orbitdust.art has Transformations enabled, so
// /cdn-cgi/image/<opts>/<source> resizes + re-encodes (AVIF/WebP via format=auto)
// on the fly and edge-caches the result. Absolute base so it works even if the
// page is opened on the *.pages.dev URL.
const SITE_BASE = "https://orbitdust.art";
const CF_WIDTHS = [400, 600, 900, 1280];
function cfImg(name: string, w: number) {
	return `${SITE_BASE}/cdn-cgi/image/width=${w},quality=80,format=auto/${R2_BASE}/${encodeURIComponent(name)}`;
}
function cfSrcset(name: string) {
	return CF_WIDTHS.map((w) => `${cfImg(name, w)} ${w}w`).join(", ");
}
// Portrait fills 1 of 4 columns (~25vw mobile / ~285px desktop); landscape fills 2 (~50vw / ~575px).
const PORTRAIT_SIZES = "(max-width: 640px) 25vw, 285px";
const LANDSCAPE_SIZES = "(max-width: 640px) 50vw, 575px";

// Load photo list from the committed manifest — no local filesystem access needed.
// All images are served from Cloudflare R2.
const sized = photosManifest.map(({ name, landscape }) => {
	const url = `${R2_BASE}/${encodeURIComponent(name)}`;
	return { src: url, slideSrc: url, fullSrc: url, landscape, name };
});

// Shuffle (Fisher-Yates) — used for the slideshow order.
function shuffle<T>(arr: T[]): T[] {
	const out = [...arr];
	for (let i = out.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[out[i], out[j]] = [out[j], out[i]];
	}
	return out;
}

// Gallery order is randomized; the client re-shuffles on every page load too,
// so this build-time order is just the initial (hidden) placeholder.
const gallery = shuffle(sized);
// Slideshow: all landscape photos in randomized order. Uses a Cloudflare-resized
// 600px variant for the tiny camera LCD, with the full-size original as a fallback.
const slideshow = shuffle(sized.filter((p) => p.landscape)).map((p) => ({ thumb: cfImg(p.name, 600), full: p.fullSrc }));

// Group into rows: a landscape photo takes the space of two portraits,
// so each row holds either 4 portraits, or 2 portraits + 1 landscape.
type Row = { items: typeof gallery; cols: number };
const rows: Row[] = [];
let row: typeof gallery = [];
let used = 0;
let landscapeLeftNext = true;
function arrangeRow(r: typeof gallery): typeof gallery {
	const ls = r.filter(p => p.landscape);
	const ps = r.filter(p => !p.landscape);
	if (ls.length > 0 && ps.length > 0) {
		const result = landscapeLeftNext ? [...ls, ...ps] : [...ps, ...ls];
		landscapeLeftNext = !landscapeLeftNext;
		return result;
	}
	return [...ls, ...ps];
}
for (const photo of gallery) {
	const cost = photo.landscape ? 2 : 1;
	if (used + cost > 4) {
		rows.push({ items: arrangeRow(row), cols: used });
		row = [];
		used = 0;
	}
	row.push(photo);
	used += cost;
}
if (row.length) {
	rows.push({ items: arrangeRow(row), cols: used });
}
